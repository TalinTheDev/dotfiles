{
   "app": {
      "background": {
         "persistent": true,
         "scripts": [ "js/background.js" ]
      }
   },
   "default_locale": "en",
   "description": "__MSG_appDescription__",
   "icons": {
      "128": "img/testnav-icon.png"
   },
   "key": "",
