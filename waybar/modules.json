{
  "hyprland/workspaces": {
        "active-only": false,
        "all-outputs": true,
        "disable-scroll": false,
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "on-scroll-down": "hyprctl dispatch workspace +1",
        "format": "{name}",
        "on-click": "activate",
    },

    "clock#hour": {
      "format": "{:%H}"
    },
    "clock#min": {
      "format": "{:%M}"
    }
}
