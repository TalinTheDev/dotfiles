{
    "position": "top",
    "layer": "top",
    "height": 25,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "custom/brightness",
        "battery",
        "network",
        "clock"
    ],
    "hyprland/workspaces": {
        "active-only": false,
        "all-outputs": true,
        "disable-scroll": false,
        "on-scroll-up": "hyprctl dispatch workspace -1",
        "on-scroll-down": "hyprctl dispatch workspace +1",
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": "",
            "sort-by-number": true
        }
    },
    "hyprland/window": {
        "rewrite": {}
    },
    "custom/brightness": {
        "exec": "~/.config/scripts/getBrightness.sh",
        "return-type": "string",
        "signal": 5,
        "interval": 60
    },
    "clock": {
        "interval": 1,
        "format": "{:%I:%M:%S}",
        "format-alt": "{:%A, %B %e}"
    },
    "network": {
        "format-wifi": "{icon}",
        "format-disconnected": "󰤭",
        "tooltip-format-wifi": "{essid} - {signalStrength}%",
        "tooltip-format-disconnected": "Disconnected",
        "format-icons": [
            "󰤟",
            "󰤢",
            "󰤥",
            "󰤨"
        ]
    },
    "pulseaudio": {
        "format": "",
        "format-muted": "󰝟",
        "format-low": "󰕿",
        "format-half": "󰖀",
        "format-medium": "󰕾",
        "tooltip-format": "Volume At {volume}%",
        "states": {
            "muted": 1,
            "low": 25,
            "half": 50,
            "medium": 75
        }
    },
    "battery": {
        "format-critical": "󰂎",
        "format-one-fourth": "󰁼",
        "format-half": "󰁾",
        "format-three-fourths": "󰂀",
        "format-full": "󰁹",
        "tooltip-format": "Battery At {capacity}% - {time}",
        "max-length": 6,
        "states": {
            "critical": 15,
            "one-fourth": 25,
            "half": 50,
            "three-fourths": 75,
            "full": 100
        }
    }
}